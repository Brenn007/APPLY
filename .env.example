# Clé API Jules (Google) — Moteur d'exécution autonome des tâches APPLY
# Obtenez votre clé sur https://jules.google.com
JULES_API_KEY=ta_clé_jules_ici

# Clé API Groq — 100% gratuite, 14 400 req/jour, modèle Llama 3.3 70B
# Inscription sur https://console.groq.com → "Create API Key"
GROQ_API_KEY=gsk_...

# API France Travail (Pôle Emploi) — Scraping réel des offres d'alternance
# Inscription gratuite sur https://francetravail.io/data/api
# → Créer une application → copier Client ID et Client Secret
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Optionnel : forcer l'environnement de développement
NODE_ENV=development
